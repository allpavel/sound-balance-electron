{
	"extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
	"include": [
		"electron.vite.config.*",
		"src/main/**/*",
		"src/preload/**/*",
		"./types.ts",
		"src/main/constants.ts"
	],
	"compilerOptions": {
		"composite": true,
		"types": [
			"electron-vite/node"
		],
		"baseUrl": ".",
		"paths": {
			"@main/*": [
				"src/main/*"
			],
			"@/*": [
				"./*"
			]
		}
	}
}